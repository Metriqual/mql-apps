# Metriqual proxy keys — create at https://metriqual.com
# Both keys should point at the same provider + model.

# Key with NO filters attached
MQL_KEY_RAW=mql-...

# Key with a hallucination blocker filter attached
# (dashboard → Anti-Halluc → New Filter, or:
#  mql hallucination create -n truthlens -s react,cove --key <this-key>)
MQL_KEY_VERIFIED=mql-...

# Optional overrides
# MQL_BASE_URL=https://api.metriqual.com
# MQL_MODEL=gpt-4o-mini
